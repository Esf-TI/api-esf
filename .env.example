# Copie para .env e preencha. Não commite o .env.

# App (Prisma Client + pg): use a URL que o Node deve usar em runtime.
# Ex.: Postgres direto na VPS (substitua HOST e a senha do painel).
DATABASE_URL="postgresql://postgres:SUA_SENHA@HOST_OU_IP:5432/postgres?schema=public"

# Migrações (prisma.config.ts): no Prisma 7 usa DIRECT_URL se existir; senão DATABASE_URL.
# Com pooler (PgBouncer), deixe DATABASE_URL apontando ao pooler e DIRECT_URL ao Postgres direto :5432.
# Sem pooler, pode ser igual ao DATABASE_URL.
DIRECT_URL="postgresql://postgres:SUA_SENHA@HOST_OU_IP:5432/postgres?schema=public"

# Se o provedor exigir TLS explícito, experimente acrescentar à URL:
# ?schema=public&sslmode=require

# MinIO (opcional — só se algum script ou cliente S3 usar direto)
# MINIO_ENDPOINT=http://HOST:9000
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
